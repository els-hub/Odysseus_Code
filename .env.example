# Odysseus_Code — example environment.
# Copy the values you need into your Odysseus .env (the installer can do this for you).
# You only need the keys for the provider(s) you chose during install.

# ── API providers (most users) ────────────────────────────────────────────────
# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI (GPT)
OPENAI_API_KEY=

# OpenRouter / Groq / others are auto-detected by Odysseus core from their base URLs.

# ── Local models (optional) ───────────────────────────────────────────────────
# If you run Ollama locally, point Odysseus at it (native API, not /v1, is preferred
# for the coding tab so context-window + reasoning controls work).
OLLAMA_BASE_URL=http://localhost:11434
